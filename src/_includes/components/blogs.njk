<div class="staggered-feed">
    {% for post in collections['posts'] %}
    <article class="project-card" data-index="LOG_{{ loop.index }}">
        <div class="card-hex mono">
            0x0{{ loop.index }}
        </div>
        
        <header class="card-header">
            <h3 class="mono uppercase card-title">{{ post.data.title }}</h3>
            <div class="tag-row">
                <span class="tag mono">{{ post.date | dateFilter }}</span>
                <span class="tag mono">FRAGMENT</span>
            </div>
        </header>

        <p class="project-summary">{{ post.data.description or "Retrieved memory fragment." }}</p>

        <a href="{{ post.url }}" class="module-link mono">READ_LOG →</a>
    </article>
    {% endfor %}
</div>
