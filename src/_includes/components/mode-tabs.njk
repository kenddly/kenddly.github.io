<div class="mode-shell">
    <div class="mode-tabs">
        <button class="tab active" data-mode="project">
            <span class="tab-label mono">PROJECTS</span>
        </button>

        <div class="mode-track">
            <span class="mode-dot"></span>
            <span class="mode-label mono" id="modeLabel">
                STREAMING: PROJECTS
            </span>
        </div>

        <button class="tab" data-mode="blog">
            <span class="tab-label mono">BLOG</span>
        </button>
    </div>


    <div class="mode-bus">
        <span class="bus-dot"></span>
    </div>
    <div class="feed-spine"></div>
</div>
