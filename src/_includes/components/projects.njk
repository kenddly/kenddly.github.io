<div class="staggered-feed">
    {% for project in collections['projects'] %}
    <article class="project-card" data-index="0x0{{ loop.index }}">
        <div class="card-hex mono">
            0x0{{ loop.index }}
        </div>

        <header class="card-header">
            <h3 class="mono uppercase card-title">
                {{ project.data.title }}
            </h3>
            <div class="tag-row">
                {% for tag in project.data.tags %}
                {% if tag != "project" %}
                <span class="tag mono">
                    {{ tag }}
                </span>
                {% endif %}
                {% endfor %}
            </div>
        </header>

        <p class="project-summary">
        {{ project.data.description }}
        </p>

        <a href="{{ project.url }}" class="module-link mono">
            ENTER →
        </a>
    </article>
    {% endfor %}
</div>
